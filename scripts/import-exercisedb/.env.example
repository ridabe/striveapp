# Copie para .env e preencha. Rode com: node --env-file=.env scripts/import-exercisedb/import.mjs

# --- RapidAPI / ExerciseDB ---
RAPIDAPI_KEY=cole_sua_chave_aqui
RAPIDAPI_HOST=exercisedb.p.rapidapi.com

# --- Supabase (use a SERVICE ROLE key, NUNCA a anon) ---
SUPABASE_URL=https://lodetzmtsymvnjffmvat.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole_a_service_role_key_aqui

# --- Parâmetros da importação ---
IMPORT_LIMIT=500
PAGE_SIZE=50
BUCKET=exercise-videos

# Proteção da chave de TESTE (gratuita): limite de chamadas metradas.
# Teste: MAX_API_CALLS=10  |  Produção (chave paga): MAX_API_CALLS=9999
MAX_API_CALLS=10
REQUEST_DELAY_MS=350

# --- Tradução (opcional) — escolha UM. Sem nenhum, salva em inglês. ---
# DEEPL_API_KEY=xxxx:fx
# GOOGLE_TRANSLATE_API_KEY=xxxx

# --- Flags de teste ---
# DRY_RUN=1   # não grava nada (só simula e loga)
# SKIP_MEDIA=1 # não baixa GIFs (economiza tempo/banda no teste)
